# =============================================================================
# Arbiter Configuration — NEBULA:FOG 2026 AI Judge
# =============================================================================
# Copy this file to .env and fill in required values.
# Lines marked [REQUIRED] must be set. All others have sensible defaults.

# -----------------------------------------------------------------------------
# Capture Layer — Gemini Live API
# -----------------------------------------------------------------------------

# [REQUIRED] Google AI Studio API key for Gemini Live API
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenCV camera device index (default: 0 = built-in camera)
CAMERA_DEVICE_INDEX=0

# PyAudio input device index (default: system default microphone)
# Leave empty to auto-select. Run `python -m pyaudio` to list devices.
AUDIO_DEVICE_INDEX=

# Frames per second to capture from camera (default: 1.0)
FRAME_RATE=1.0

# Histogram correlation threshold for key frame detection (default: 0.4)
# Lower values = more sensitive to scene changes
KEY_FRAME_THRESHOLD=0.4

# -----------------------------------------------------------------------------
# Commentary — TTS via Cartesia
# -----------------------------------------------------------------------------

# Cartesia API key for text-to-speech (optional — degrades gracefully to text-only)
CARTESIA_API_KEY=

# Cartesia voice ID for the Arbiter persona
CARTESIA_VOICE_ID=

# -----------------------------------------------------------------------------
# Display Server
# -----------------------------------------------------------------------------

# Host/port for the FastAPI display and operator dashboard server
DISPLAY_HOST=0.0.0.0
DISPLAY_PORT=8080

# -----------------------------------------------------------------------------
# Operator Security
# -----------------------------------------------------------------------------

# Token for WebSocket operator authentication (optional)
# When set, operator dashboard must include ?token= in the URL.
# When empty, all WebSocket connections are accepted (dev mode).
OPERATOR_TOKEN=

# -----------------------------------------------------------------------------
# Demo Timer
# -----------------------------------------------------------------------------

# Maximum demo duration in seconds before operator gets warned (default: 600 = 10 min)
# Warning fires at 90% of this value, critical alert at 100%.
MAX_DEMO_DURATION=600

# -----------------------------------------------------------------------------
# LLM Providers (optional — for MoE scoring and enrichment)
# -----------------------------------------------------------------------------

# Anthropic API key for Claude (used in MoE scoring ensemble and video analysis)
ANTHROPIC_API_KEY=

# OpenAI API key (used in MoE scoring ensemble and TTS fallback)
OPENAI_API_KEY=

# Groq API key for fast inference (used in commentary and Q&A generation)
GROQ_API_KEY=

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# Enable MoE (Mixture of Experts) multi-model scoring
# When true, scores from multiple LLM providers are aggregated for robustness.
# Requires at least one additional provider key (ANTHROPIC, OPENAI, or GROQ).
MOE_SCORING_ENABLED=false

# Enable commentary enrichment post-processing
# When true, generated commentary is refined by a second LLM pass.
# Adds latency but improves text quality.
COMMENTARY_ENRICHMENT_ENABLED=false
