# Google AI Studio API key for Gemini Live API
GEMINI_API_KEY=

# OpenCV camera device index (default: 0)
CAMERA_DEVICE_INDEX=0

# PyAudio input device index (default: None for system default)
AUDIO_DEVICE_INDEX=

# Frames per second to capture (default: 1.0)
FRAME_RATE=1.0

# Histogram correlation threshold for scene change detection (default: 0.4)
# Lower values = more sensitive to changes
KEY_FRAME_THRESHOLD=0.4
